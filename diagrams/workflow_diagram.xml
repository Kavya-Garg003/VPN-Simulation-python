        <!-- Key Exchange -->
        <mxCell id="4" value="Key Exchange" style="rounded=1;fillColor=#ffe6cc;" vertex="1" parent="1">
          <mxGeometry x="200" y="180" width="200" height="60" as="geometry"/>
